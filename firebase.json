{
  "firestore": {
    "database": "(default)",
    "location": "europe-west1",
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      { "source": "/portfolio/**", "destination": "/public.html" },
      { "source": "/review/**",    "destination": "/public.html" },
      { "source": "**",            "destination": "/index.html"  }
    ]
  },
  "auth": {
    "providers": {
      "emailPassword": true,
      "googleSignIn": {
        "oAuthBrandDisplayName": "TailorPady",
        "supportEmail": "uchenduuchenna7@gmail.com"
      }
    }
  }
}